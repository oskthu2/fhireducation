# ─── COS (Cambio Open Services) ─────────────────────────────────────────────
# From the COS Quick Start guide (developer.openservices.cambio.se)

# FHIR R4 base URL
COS_FHIR_BASE_URL=https://api.openservices.cambio.se/api/open/fhir

# OAuth 2.0 token endpoint (Keycloak, Basic auth)
COS_TOKEN_URL=https://api.openservices.cambio.se/auth/realms/COS/protocol/openid-connect/token

# Client ID and secret (used for Basic auth on the token endpoint)
COS_CLIENT_ID=your-client-id
COS_CLIENT_SECRET=your-client-secret

# API subscription key (Ocp-Apim-Subscription-Key — from your profile in the developer portal)
COS_API_KEY=your-api-key

# Scope (default is sufficient for sandbox)
COS_SCOPE=user/*.read user/*.write

# ─── Extraction settings ─────────────────────────────────────────────────────

# Comma-separated personnummer to look up and extract data for.
# The extractor resolves these to FHIR Patient IDs, then fetches all
# linked resources (Conditions, Observations, MedicationRequests, etc.).
EXTRACT_PATIENT_IDENTIFIERS=194706302595

# Alternatively, supply FHIR Patient.id values directly to skip lookup.
# EXTRACT_PATIENT_IDS=patient-001,patient-002

# Resource types to extract (comma-separated).
# Patient-linked types are fetched per patient; standalone types are listed globally.
EXTRACT_RESOURCE_TYPES=Patient,Condition,MedicationRequest,Observation,Encounter,AllergyIntolerance,Practitioner,Organization

# Maximum resources per type (across all patients). Keep low to avoid rate limits.
EXTRACT_COUNT_PER_TYPE=50

# Output directory for the generated JSON bundle files (relative to extract.ts).
# Default: ../data  (directly into the sandbox data/ folder)
# EXTRACT_OUTPUT_DIR=../data
