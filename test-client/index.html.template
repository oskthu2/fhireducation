<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FHIR Test Client</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 2rem; line-height: 1.4; }
    code, pre { background: #f3f3f3; padding: 0.2rem 0.4rem; border-radius: 4px; }
    pre { overflow-x: auto; padding: 1rem; }
    .label { font-weight: bold; }
  </style>
</head>
<body>
  <h1>FHIR Test Client</h1>
  <p><span class="label">Configured FHIR version:</span> <code>${FHIR_VERSION}</code></p>
  <p><span class="label">Loaded bundle resource type:</span> <code id="resourceType">...</code></p>
  <p><span class="label">Loaded patient id:</span> <code id="patientId">...</code></p>
  <p><span class="label">Loaded patient display:</span> <code id="patientDisplay">...</code></p>
  <h2>Bundle JSON</h2>
  <pre id="bundle"></pre>

  <script>
    fetch('./bundle.json')
      .then(response => response.json())
      .then(bundle => {
        document.getElementById('resourceType').textContent = bundle.resourceType || 'unknown';
        const patient = (bundle.entry || []).map(e => e.resource).find(r => r && r.resourceType === 'Patient');
        document.getElementById('patientId').textContent = patient?.id || 'not found';
        const family = patient?.name?.[0]?.family || '';
        const given = (patient?.name?.[0]?.given || []).join(' ');
        document.getElementById('patientDisplay').textContent = `${given} ${family}`.trim() || 'not found';
        document.getElementById('bundle').textContent = JSON.stringify(bundle, null, 2);
      })
      .catch(error => {
        document.getElementById('bundle').textContent = `Failed to load bundle.json: ${error}`;
      });
  </script>
</body>
</html>
